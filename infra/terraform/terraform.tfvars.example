# Copy this to terraform.tfvars and fill in real values. terraform.tfvars is
# gitignored — never commit your real IP or key path publicly.

aws_region       = "eu-north-1"
instance_type    = "t3.micro"          # bump to t3.small only when demoing Minikube live
key_pair_name    = "devops-lab-key"
public_key_path  = "~/.ssh/devops_lab_key.pub"
allowed_ssh_cidr = "203.0.113.10/32"   # replace with YOUR current public IP + /32
project_name     = "devops-lab"
